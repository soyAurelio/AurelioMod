# AurelioMod — Variables de Entorno para Producción (Fase 2a)
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env al repositorio.

# ============================================================
# Dominio
# ============================================================
DOMAIN=api.aureliomod.com
LETSENCRYPT_EMAIL=admin@aureliomod.com

# ============================================================
# NATS — nkey authentication (Fase 2+)
# ============================================================
NATS_NKEY_SEED=

# ============================================================
# Neon DB (PostgreSQL managed)
# ============================================================
NEON_DATABASE_URL=

# ============================================================
# Weaviate Cloud (Vector Database — L3)
# ============================================================
WEAVIATE_HOSTNAME=
WEAVIATE_API_KEY=

# ============================================================
# Cloudflare R2 (Object Storage — S3 compatible)
# ============================================================
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aureliomod

# ============================================================
# Feature Gates (producción)
# ============================================================
R2_AUDIT_ENABLED=true
NEON_AUDIT_ENABLED=true
MEDIA_SANDBOX_ENABLED=true
WEBRISK_ENABLED=true
YTDLP_SIDECAR_ENABLED=true

# ============================================================
# WaveSpeed AI (Content Moderation)
# ============================================================
WAVESPEED_API_KEY=
WAVESPEED_PLAN=bronze

# ============================================================
# Stripe (Pagos — live mode)
# ============================================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BRONZE=price_...
# STRIPE_PRICE_SILVER=price_...
# STRIPE_PRICE_GOLD=price_...
# CONTROL_BASE_URL=https://api.aureliomod.com

# ============================================================
# Discord Bot
# ============================================================
DISCORD_TOKEN=
REQUIRED_GUILD_ID=
ENFORCE_MODERATION=true
BOT_LANG=es

# ============================================================
# PASETO (Auth Tokens)
# ============================================================
PASETO_SECRET_KEY=

# ============================================================
# pprof admin (debug endpoint)
# ============================================================
PPROF_ADMIN_KEY=

# ============================================================
# Google Web Risk API (URL safety check)
# ============================================================
WEBRISK_API_KEY=

# ============================================================
# Go Memory Limit (previene OOM en VPS de 1GB)
# ============================================================
GOMEMLIMIT=200MiB

# ============================================================
# Grafana Cloud — OpenTelemetry (métricas + trazas + logs)
# ============================================================
# Free tier: https://grafana.com → My Account → Grafana Cloud
# Endpoint y credenciales desde: Cloud Portal → OpenTelemetry → Linux → Direct
# La región recomendada es prod-sa-east-1 (São Paulo, mismo datacenter que Vultr)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-instanceId:token>
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=AurelioMod
OTEL_RESOURCE_ATTRIBUTES=service.namespace=aureliomod-group
