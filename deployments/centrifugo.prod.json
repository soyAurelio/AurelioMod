{
  "client": {
    "token": {
      "hmac_secret_key": "${CENTRIFUGO_TOKEN_HMAC_SECRET_KEY}"
    },
    "allowed_origins": ["${CENTRIFUGO_ALLOWED_ORIGINS}"],
    "insecure": false
  },
  "http_api": {
    "key": "${CENTRIFUGO_HTTP_API_KEY}"
  },
  "admin": {
    "password": "${CENTRIFUGO_ADMIN_PASSWORD}",
    "secret": "${CENTRIFUGO_ADMIN_SECRET}",
    "enabled": true,
    "insecure": false
  }
}
