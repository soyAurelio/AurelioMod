{
  "title": "AurelioMod Engine",
  "uid": "aureliomod-engine",
  "panels": [
    {
      "title": "Analysis Rate (req/s)",
      "type": "graph",
      "targets": [{ "expr": "rate(engine_analysis_total[1m])" }]
    },
    {
      "title": "Analysis Duration (p50/p95/p99)",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(engine_analysis_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(engine_analysis_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(engine_analysis_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Cache Hit Rate (L1/L2/L3)",
      "type": "graph",
      "targets": [
        { "expr": "rate(cache_hits_total{level='l1'}[1m])", "legendFormat": "L1 BLAKE3" },
        { "expr": "rate(cache_hits_total{level='l2'}[1m])", "legendFormat": "L2 pHash" },
        { "expr": "rate(cache_hits_total{level='l3'}[1m])", "legendFormat": "L3 Weaviate" }
      ]
    },
    {
      "title": "WaveSpeed API Errors",
      "type": "graph",
      "targets": [{ "expr": "rate(wavespeed_errors_total[1m])" }]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "targets": [{ "expr": "circuit_breaker_state{breaker='wavespeed'}" }]
    },
    {
      "title": "Workspace Quota Usage (top 5)",
      "type": "bargauge",
      "targets": [{ "expr": "topk(5, workspace_analysis_count / workspace_analysis_limit)" }]
    }
  ]
}
