{
  "version": 3,
  "name": "AurelioMod API Gateway",
  "port": 8080,
  "timeout": "10s",
  "cache_ttl": "0s",
  "host": [
    "0.0.0.0"
  ],
  "extra_config": {
    "telemetry/logging": {
      "level": "ERROR",
      "stdout": true,
      "format": "json"
    },
    "auth/validator": {
      "validator": {
        "endpoint": "/v1/auth/verify",
        "host": [
          "http://control:8080"
        ],
        "headers_to_pass": [
          "Authorization"
        ],
        "cache": true,
        "cache_duration": 300
      }
    }
  },
  "endpoints": [
    {
      "endpoint": "/healthz",
      "method": "GET",
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/healthz"
        }
      ]
    },
    {
      "endpoint": "/v1/auth/login",
      "method": "POST",
      "input_headers": [
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 10,
          "client_max_rate": 5,
          "strategy": "ip",
          "every": "1m"
        }
      },
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/auth/login",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/v1/auth/refresh",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/auth/refresh",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/workspaces",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 100,
          "client_max_rate": 20,
          "strategy": "ip"
        },
        "auth/validator": true
      },
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/v1/workspaces",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 20,
          "client_max_rate": 5,
          "strategy": "ip"
        },
        "auth/validator": true
      },
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/v1/workspaces/{id}",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces/{id}",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/workspaces/{id}/stats",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces/{id}/stats",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/workspaces/{id}/decisions",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces/{id}/decisions",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/workspaces/{id}/decisions/{audit_id}",
      "method": "GET",
      "input_headers": [
        "Authorization"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces/{id}/decisions/{audit_id}",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/billing/checkout",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/billing/checkout",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/billing/portal",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/billing/portal",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ],
      "extra_config": {
        "auth/validator": true
      }
    },
    {
      "endpoint": "/v1/webhooks/stripe",
      "method": "POST",
      "input_headers": [
        "Content-Type",
        "Stripe-Signature"
      ],
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/webhooks/stripe",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/billing/success",
      "method": "GET",
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/billing/success",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/billing/cancel",
      "method": "GET",
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/billing/cancel",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/v1/workspaces/{id}/consume",
      "method": "POST",
      "input_headers": [
        "Authorization",
        "Content-Type"
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 200,
          "client_max_rate": 50,
          "strategy": "ip"
        },
        "auth/validator": true
      },
      "backend": [
        {
          "host": [
            "http://control:8080"
          ],
          "url_pattern": "/v1/workspaces/{id}/consume",
          "extra_config": {
            "qos/health-check": {
              "url": "http://control:8080/healthz",
              "timeout": "3s"
            }
          }
        }
      ]
    }
  ]
}
