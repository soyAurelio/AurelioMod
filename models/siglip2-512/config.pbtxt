# Triton Inference Server — SigLIP2 model configuration
# Model: google/siglip2-so400m-patch16-512
# Unified ONNX: input_ids + pixel_values → logits_per_image, image_embeds, text_embeds

name: "siglip2-512"
platform: "onnxruntime_onnx"
default_model_filename: "model.onnx"
max_batch_size: 48

input [
  {
    name: "pixel_values",
    data_type: TYPE_FP32,
    dims: [3, 512, 512]
  },
  {
    name: "input_ids",
    data_type: TYPE_INT64,
    dims: [-1]
  }
]

output [
  {
    name: "logits_per_image",
    data_type: TYPE_FP32,
    dims: [-1]
  },
  {
    name: "text_embeds",
    data_type: TYPE_FP32,
    dims: [1152]
  },
  {
    name: "image_embeds",
    data_type: TYPE_FP32,
    dims: [1152]
  }
]

dynamic_batching {
  max_queue_delay_microseconds: 5000
  preferred_batch_size: [4, 8, 16, 32, 48]
  preserve_ordering: false
}

instance_group [
  {
    count: 1,
    kind: KIND_GPU,
    gpus: [0]
  }
]

optimization {
  execution_accelerators {
    gpu_execution_accelerator [
      {
        name: "cuda"
        parameters { key: "cudnn_conv_algo_search", value: "EXHAUSTIVE" }
        parameters { key: "gpu_mem_limit", value: "4294967296" }
      }
    ]
  }
}

model_warmup [
  {
    name: "warmup_b4"
    batch_size: 4
    inputs: {
      key: "pixel_values"
      value: { data_type: TYPE_FP32, dims: [3, 512, 512], zero_data: true }
    }
    inputs: {
      key: "input_ids"
      value: { data_type: TYPE_INT64, dims: [64], zero_data: true }
    }
  }
]

version_policy: { latest: { num_versions: 1 } }
